{
  "hosting": {
    "public": "public",
    "ignore": [
      "node_modules/**",
      ".git/**",
      "firebase.json",
      "firestore.rules",
      "firestore.indexes.json",
      ".firebaserc",
      "functions/**",
      "dataconnect/**",
      "codebase/**",
      "web-app/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}